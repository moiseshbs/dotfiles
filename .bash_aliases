alias gdir='cd /c/Git'
alias cls='clear'
alias ..='cd ..'
alias ex='explorer .'

alias gpdev='git pull origin develop'
alias gphere='git pull origin $(git branch --show-current)'
alias gpush='git push origin $(git branch --show-current)'
alias gs='git status'

alias db='dotnet build'
alias dr='dotnet run'
alias dc='dotnet clean'
alias dt='dotnet test'

alias bash-help='bash-help'